import { useState } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Wallet, PlusCircle, ArrowUpRight, Loader, AlertCircle } from 'lucide-react';
import { supabase } from '../lib/supabase';
import { useAuth } from '../contexts/AuthContext';

export default function WalletPage() {
  const { user, profile, refreshProfile } = useAuth();
  const [showDeposit, setShowDeposit] = useState(false);
  const [showWithdraw, setShowWithdraw] = useState(false);

  return (
    <div>
      <h1 className="text-[18px] font-semibold text-black mb-4">Wallet</h1>

      {/* Balance card */}
      <div className="glass-card p-5 mb-4">
        <div className="flex items-center gap-3 mb-4">
          <div className="w-10 h-10 rounded-full bg-black/5 flex items-center justify-center">
            <Wallet size={18} className="text-black" />
          </div>
          <div>
            <p className="text-[10px] text-black/40 uppercase tracking-wider font-medium">Available Balance</p>
            <p className="text-2xl font-bold text-black">€{(profile?.balance ?? 0).toFixed(2)}</p>
          </div>
        </div>
        <div className="flex gap-2">
          <button
            onClick={() => setShowDeposit(true)}
            className="btn-primary flex-1 py-3 text-xs flex items-center justify-center gap-1.5"
          >
            <PlusCircle size={14} /> Deposit
          </button>
          <button
            onClick={() => setShowWithdraw(true)}
            className="btn-secondary flex-1 py-3 text-xs flex items-center justify-center gap-1.5 text-black/60"
          >
            <ArrowUpRight size={14} /> Withdraw
          </button>
        </div>
      </div>

      {/* Fairness messaging */}
      <div className="glass-card p-4">
        <p className="text-[10px] font-semibold text-black/40 uppercase tracking-wider mb-2">How it works</p>
        <p className="text-[11px] text-black/30 leading-4">Every loss increases your winning power. You can win multiple times. Your 10th game is guaranteed if you haven't won. Nobody can lose more than 9 consecutive games.</p>
      </div>

      {/* Deposit Modal */}
      <AnimatePresence>
        {showDeposit && <DepositModal onClose={() => setShowDeposit(false)} />}
      </AnimatePresence>

      {/* Withdraw Modal */}
      <AnimatePresence>
        {showWithdraw && <WithdrawModal onClose={() => setShowWithdraw(false)} />}
      </AnimatePresence>
    </div>
  );
}

function DepositModal({ onClose }: { onClose: () => void }) {
  const { user, refreshProfile } = useAuth();
  const [amount, setAmount] = useState('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');

  async function handleDeposit(e: React.FormEvent) {
    e.preventDefault();
    const val = parseFloat(amount);
    if (!val || val < 1) { setError('Minimum €1'); return; }
    setLoading(true);
    setError('');

    await supabase.from('transactions').insert({
      user_id: user!.id,
      type: 'deposit',
      amount: val,
      description: `Deposit €${val.toFixed(2)}`,
      status: 'completed',
    });
    const { data } = await supabase.from('profiles').select('balance').eq('id', user!.id).maybeSingle();
    const newBal = (data?.balance ?? 0) + val;
    await supabase.from('profiles').update({ balance: newBal }).eq('id', user!.id);
    await refreshProfile();
    setLoading(false);
    onClose();
  }

  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      className="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div className="absolute inset-0 bg-black/20 backdrop-blur-sm" onClick={onClose} />
      <motion.div
        initial={{ scale: 0.95, opacity: 0 }}
        animate={{ scale: 1, opacity: 1 }}
        exit={{ scale: 0.95, opacity: 0 }}
        className="relative glass-card p-6 w-full max-w-[280px]"
      >
        <h2 className="text-[14px] font-semibold text-black mb-4">Deposit</h2>
        <div className="grid grid-cols-4 gap-1.5 mb-4">
          {[1, 5, 10, 25].map(p => (
            <button
              key={p}
              onClick={() => setAmount(String(p))}
              className={`py-2 rounded-[8px] text-[11px] font-semibold transition ${
                amount === String(p) ? 'bg-black text-white' : 'bg-white/30 text-black/50 border border-white/30'
              }`}
            >
              €{p}
            </button>
          ))}
        </div>
        <form onSubmit={handleDeposit} className="space-y-3">
          <input
            type="number"
            value={amount}
            onChange={e => setAmount(e.target.value)}
            placeholder="0.00"
            min="1"
            step="0.01"
            className="w-full px-3 py-2.5 glass-input text-[11px] text-black placeholder-black/25"
            required
          />
          {error && <p className="text-red-500 text-[10px]">{error}</p>}
          <button
            type="submit"
            disabled={loading}
            className="btn-primary w-full py-2.5 text-xs flex items-center justify-center gap-1.5 disabled:opacity-50"
          >
            {loading && <Loader size={12} className="animate-spin" />}
            Deposit
          </button>
        </form>
      </motion.div>
    </motion.div>
  );
}

function WithdrawModal({ onClose }: { onClose: () => void }) {
  const { user, profile, refreshProfile } = useAuth();
  const [amount, setAmount] = useState('');
  const [method, setMethod] = useState<'paypal' | 'card'>('paypal');
  const [detail, setDetail] = useState('');
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const bal = profile?.balance ?? 0;

  async function handleWithdraw(e: React.FormEvent) {
    e.preventDefault();
    const val = parseFloat(amount);
    if (!val || val < 1) { setError('Minimum €1'); return; }
    if (val > bal) { setError('Insufficient balance'); return; }
    if (!detail.trim()) { setError('Enter payment details'); return; }
    setLoading(true);
    setError('');

    await supabase.from('transactions').insert({
      user_id: user!.id,
      type: 'withdrawal',
      amount: -val,
      description: `Withdraw €${val.toFixed(2)} via ${method}`,
      status: 'completed',
    });
    await supabase.from('profiles').update({ balance: bal - val }).eq('id', user!.id);
    await refreshProfile();
    setLoading(false);
    onClose();
  }

  return (
    <motion.div
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      className="fixed inset-0 z-50 flex items-center justify-center p-4"
    >
      <div className="absolute inset-0 bg-black/20 backdrop-blur-sm" onClick={onClose} />
      <motion.div
        initial={{ scale: 0.95, opacity: 0 }}
        animate={{ scale: 1, opacity: 1 }}
        exit={{ scale: 0.95, opacity: 0 }}
        className="relative glass-card p-6 w-full max-w-[280px]"
      >
        <h2 className="text-[14px] font-semibold text-black mb-1">Withdraw</h2>
        <p className="text-[10px] text-black/30 mb-4">Available: €{bal.toFixed(2)}</p>

        <div className="grid grid-cols-2 gap-2 mb-3">
          {(['paypal', 'card'] as const).map(m => (
            <button
              key={m}
              onClick={() => setMethod(m)}
              className={`py-2 rounded-[8px] text-[11px] font-semibold capitalize transition ${
                method === m ? 'bg-black text-white' : 'bg-white/30 text-black/50 border border-white/30'
              }`}
            >
              {m === 'paypal' ? 'PayPal' : 'Card'}
            </button>
          ))}
        </div>

        <form onSubmit={handleWithdraw} className="space-y-3">
          <input
            type="number"
            value={amount}
            onChange={e => setAmount(e.target.value)}
            placeholder="0.00"
            min="1"
            max={bal}
            step="0.01"
            className="w-full px-3 py-2.5 glass-input text-[11px] text-black placeholder-black/25"
            required
          />
          <input
            type={method === 'paypal' ? 'email' : 'text'}
            value={detail}
            onChange={e => setDetail(e.target.value)}
            placeholder={method === 'paypal' ? 'PayPal email' : 'Card number'}
            className="w-full px-3 py-2.5 glass-input text-[11px] text-black placeholder-black/25"
            required
          />
          {error && (
            <div className="flex items-center gap-1 text-red-500 text-[10px]">
              <AlertCircle size={10} /> {error}
            </div>
          )}
          <button
            type="submit"
            disabled={loading || bal < 1}
            className="btn-primary w-full py-2.5 text-xs flex items-center justify-center gap-1.5 disabled:opacity-50"
          >
            {loading && <Loader size={12} className="animate-spin" />}
            Withdraw
          </button>
        </form>
      </motion.div>
    </motion.div>
  );
}
